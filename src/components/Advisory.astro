---
const pillars = [
  { n: 'i', t: 'Engineering Leadership' },
  { n: 'ii', t: 'AI Adoption' },
  { n: 'iii', t: 'Agentic Software' },
];
---

<section id="advisory" class="section">
  <div class="grid">
    <div>
      <div class="kicker">◇ Advisory</div>
      <h3>
        Available for the occasional <em>good problem</em>.
      </h3>
      <p>
        One client at a time, generally remote, generally a day or two each month.
        If your work overlaps with the topics on the right, get in touch.
      </p>
      <a class="email" href="mailto:hello@eigenstack.co">hello@eigenstack.co →</a>
    </div>

    <div>
      {
        pillars.map((p, i) => (
          <div class="pillar" data-first={i === 0}>
            <div class="num">{p.n}.</div>
            <div class="lbl">{p.t}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .section {
    padding: 88px 0;
    margin-top: 64px;
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
  }

  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
  }

  .kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  h3 {
    font-family: var(--display);
    font-size: 44px;
    font-weight: 400;
    letter-spacing: -1px;
    margin: 0 0 20px;
    line-height: 1.05;
    text-wrap: pretty;
  }

  h3 em {
    font-style: italic;
    color: var(--accent);
  }

  p {
    font-size: 15px;
    color: var(--ink-soft);
    line-height: 1.6;
    max-width: 460px;
    text-wrap: pretty;
    margin: 0;
  }

  .email {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 28px;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 0.4px;
  }

  .pillar {
    padding: 18px 0;
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 16px;
    align-items: baseline;
    border-bottom: 1px solid var(--rule);
  }

  .pillar[data-first='true'] {
    border-top: 1px solid var(--rule);
  }

  .num {
    font-family: var(--display);
    font-size: 16px;
    font-style: italic;
    color: var(--accent);
  }

  .lbl {
    font-family: var(--display);
    font-size: 24px;
    font-weight: 500;
    letter-spacing: -0.4px;
  }

  @media (max-width: 900px) {
    .section {
      padding: 56px 0;
      margin-top: 40px;
    }

    .grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    h3 {
      font-size: 32px;
    }

    .lbl {
      font-size: 20px;
    }
  }
</style>
