---
interface Props {
  size?: number;
  color?: string;
}

const { size = 22, color = 'currentColor' } = Astro.props;
---

<svg width={size} height={size} viewBox="0 0 24 24" aria-hidden="true">
  <rect x="3" y="5" width="18" height="2.4" fill={color} />
  <rect x="3" y="10.8" width="13" height="2.4" fill={color} />
  <rect x="3" y="16.6" width="8" height="2.4" fill={color} />
</svg>
