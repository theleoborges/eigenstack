---
import EigenMark from './EigenMark.astro';
---

<footer id="about" class="footer">
  <div>
    <EigenMark size={20} color="var(--ink)" />
    <div class="legal-name">Eigenstack Pty Ltd</div>
    <div>ABN 00 000 000 000</div>
    <div>Melbourne · Australia</div>
  </div>

  <div>
    <div class="col-head">Properties</div>
    <div><a href="https://liv4all.com">liv4all.com</a></div>
    <div><a href="https://leonardoborges.com">leonardoborges.com</a></div>
  </div>

  <div>
    <div class="col-head">Contact</div>
    <div><a href="mailto:hello@eigenstack.co">hello@eigenstack.co</a></div>
    <div>
      <a href="https://www.linkedin.com/in/leonardoborges/">linkedin</a> ·
      <a href="https://github.com/leonardoborges">github</a>
    </div>
  </div>

  <div class="version">
    © 2026<br />
    v1.0
  </div>
</footer>

<style>
  .footer {
    padding-top: 56px;
    margin-top: 48px;
    border-top: 1px solid var(--rule);
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 32px;
    font-size: 12px;
    color: var(--ink-soft);
    font-family: var(--mono);
    letter-spacing: 0.3px;
  }

  .footer a {
    color: inherit;
    text-decoration: none;
  }

  .footer a:hover {
    color: var(--ink);
  }

  .legal-name {
    margin-top: 14px;
    color: var(--ink);
    font-size: 13px;
    letter-spacing: 0.2px;
  }

  .col-head {
    color: var(--ink-faint);
    margin-bottom: 10px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .version {
    text-align: right;
    color: var(--ink-faint);
  }

  @media (max-width: 700px) {
    .footer {
      grid-template-columns: 1fr 1fr;
      gap: 28px;
    }

    .version {
      text-align: left;
    }
  }
</style>
