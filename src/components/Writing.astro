---
const posts = [
  {
    n: '#42',
    d: 'APR 24',
    t: 'There Is No Best Move',
    href: 'https://leonardoborges.substack.com/p/42-there-is-no-best-move',
  },
  {
    n: '#40',
    d: 'MAR 24',
    t: 'Why Guardrails Don’t Work',
    href: 'https://leonardoborges.substack.com/p/tltd-40-why-guardrails-dont-work',
  },
  {
    n: '#39',
    d: 'MAR 10',
    t: 'Voice AI: The Next Platform Shift',
    href: 'https://leonardoborges.substack.com/p/tltd-39-voice-ai-the-next-platform',
  },
];
---

<section id="writing" class="section">
  <header class="head">
    <div>
      <div class="kicker">◇ Writing</div>
      <h3>From The LeadTech Diet</h3>
    </div>
    <a class="all" href="https://leonardoborges.substack.com">all issues ↗</a>
  </header>

  <div class="list">
    {
      posts.map((p) => (
        <a class="row" href={p.href}>
          <div class="num">{p.n}</div>
          <div class="date">{p.d}</div>
          <div class="title">{p.t}</div>
          <div class="arrow">→</div>
        </a>
      ))
    }
    <div class="end-rule"></div>
  </div>
</section>

<style>
  .section {
    padding: 64px 0 24px;
  }

  .head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 24px;
    gap: 16px;
  }

  .kicker {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--ink-soft);
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  h3 {
    font-family: var(--display);
    font-size: 32px;
    font-weight: 400;
    letter-spacing: -0.6px;
    margin: 0;
  }

  .all {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    text-decoration: none;
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .row {
    display: grid;
    grid-template-columns: 60px 80px 1fr 24px;
    gap: 24px;
    padding: 18px 0;
    border-top: 1px solid var(--rule);
    color: inherit;
    text-decoration: none;
    align-items: baseline;
    transition: background 0.15s;
  }

  .row:hover {
    background: var(--row-hover);
  }

  .num {
    font-family: var(--mono);
    font-size: 12px;
    color: var(--accent);
  }

  .date {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--ink-faint);
    letter-spacing: 0.4px;
  }

  .title {
    font-family: var(--display);
    font-size: 20px;
    letter-spacing: -0.2px;
  }

  .arrow {
    color: var(--ink-faint);
    text-align: right;
  }

  .end-rule {
    border-top: 1px solid var(--rule);
  }

  @media (max-width: 700px) {
    .row {
      grid-template-columns: 48px 1fr 16px;
      gap: 14px;
    }

    .date {
      display: none;
    }

    .title {
      font-size: 17px;
    }
  }
</style>
